{
"manifest_version" : 3,
"name": "Sid Squasher!",
"description": "Squash some Sids!",
"version": "62.37",
"permissions" : ["activeTab", "storage", "scripting", "tabs"],
"web_accessible_resources": [{"resources": ["images/sid.png", "images/pineapple.png", "images/sid2.png", "images/sid3.png", "images/sid4.png", "images/sid5.png"], "matches": ["<all_urls>"]}],
"content_scripts": [{"matches": ["<all_urls>"], "js": ["contentScript.js"]}]
}